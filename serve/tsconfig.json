{
  "compilerOptions": {
    "target": "ES2022",           // 编译成的 JS 版本，Node 现代版本支持良好
    "module": "CommonJS",         // Node.js 标准的模块系统 (如果用 ESM 可改 nodenext)
    "outDir": "./dist",           // 编译后的 JS 文件输出目录
    "rootDir": "./src",           // 你的 TS 源码目录
    "strict": true,               // 开启所有严格类型检查（强烈建议！）
    "esModuleInterop": true,      // 允许以 default 方式导入 CommonJS 模块
    "skipLibCheck": true,         // 跳过第三方库的类型检查，加快编译速度
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,    // 允许导入 JSON 文件
    "types": ["node"]             // 明确引入 @types/node
  },
  "include": ["./src/**/*"],        // 只编译 src 下的文件
  "exclude": ["node_modules", "dist"]
}